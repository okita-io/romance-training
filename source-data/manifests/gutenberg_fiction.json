{
  "repo_id": "ppirli/Gutenberg-Fiction",
  "slug": "gutenberg_fiction",
  "genres": ["fiction", "project_gutenberg"],
  "files": "**/*.parquet",
  "text_field": "text",
  "title_field": "book_title",
  "author_field": "author",
  "extra_fields": ["etextno", "issued"],
  "min_words": 100,
  "clean_prose": true,
  "strip_toc": true,
  "exclude_plays": true,
  "notes": "23k full Gutenberg books (~4.8 GB). Plays filtered out. Use convert_hf_parquet.py --chunk."
}
